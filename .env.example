# China GEO Launcher configuration
#
# Copy this file to .env and fill in values before running live campaigns.
# V1 keeps configuration simple in one file. Do not commit real secrets.

# Personal IP profile
GEO_PERSON_NAME=
GEO_PERSON_ALIASES=
GEO_PERSON_FIELD=
GEO_PERSON_POSITIONING=
GEO_TARGET_AUDIENCE=
GEO_CORE_TOPICS=
GEO_EXISTING_ACCOUNTS=
GEO_REPRESENTATIVE_ARTICLES=
GEO_FORBIDDEN_PHRASES=

# Campaign defaults
GEO_OUTPUT_DIR=geo-runs
GEO_DEFAULT_PROVIDERS=doubao,kimi,deepseek
GEO_DEFAULT_PLATFORMS=wechat,zhihu,xiaohongshu,juejin,csdn,baijiahao,woshipm,sspai

# Verification provider API keys.
# Only use an API as GEO verification when it supports web search or citation output.
DOUBAO_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=
TONGYI_API_KEY=
WENXIN_API_KEY=
YUANBAO_API_KEY=
METASO_API_KEY=
SO360_AI_API_KEY=

# Playwright verification
GEO_PLAYWRIGHT_ENABLED=true
GEO_PLAYWRIGHT_USER_DATA_DIR=.playwright-profile
GEO_PLAYWRIGHT_HEADLESS=false
GEO_PLAYWRIGHT_TIMEOUT_MS=90000

# Semi-automated publishing
GEO_PUBLISH_MODE=semi
WECHAT_DRAFT_ENABLED=false
XHS_DRAFT_ENABLED=false
ZHIHU_DRAFT_ENABLED=false
JUEJIN_DRAFT_ENABLED=false
CSDN_DRAFT_ENABLED=false
BAIJIAHAO_DRAFT_ENABLED=false
WOSHIPM_DRAFT_ENABLED=false
SSPAI_DRAFT_ENABLED=false
